# Cloudwright Environment Variables
# Required for: design, modify, chat, adr commands
# All other commands (cost, validate, export, lint, score, etc.) work offline

# Anthropic API key (recommended - uses Claude for architecture generation)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (alternative to Anthropic)
# OPENAI_API_KEY=sk-...

# Optional: API key to protect web UI endpoints (if not set, no auth required)
# CLOUDWRIGHT_API_KEY=your-secret-key

# Optional: CORS origins for web UI (comma-separated, defaults to localhost)
# CLOUDWRIGHT_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: Log format (console or json, defaults to console)
# CLOUDWRIGHT_LOG_FORMAT=console
